{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["env.d.ts", "src/**/*", "src/**/*.vue", "packages/**/*", "packages/**/*.vue"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "target": "es2022",
    "lib": ["es2022"],
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    "paths": {
      "@/*": ["./src/*"],
      "@la-rampa/elevation-cursor-sync": ["./packages/elevation-cursor-sync/src/index.ts"],
      "@la-rampa/elevation-chart": ["./packages/elevation-chart/src/index.ts"],
      "@la-rampa/track-map-utils": ["./packages/track-map-utils/src/index.ts"]
    },
    "noUncheckedIndexedAccess": false // remove this at one time ;-(
  }
}
